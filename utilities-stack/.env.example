# Paperless OCR Settings
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_OCR_LANGUAGES=deu spa chi_sim chi_tra jpn rus tur ces ara

# Postgres Settings
POSTGRES_DB=paperless
POSTGRES_USER=user
